# Flow2API Token Updater v3.3 config

# 管理员密码 (Web UI)
ADMIN_PASSWORD=your_admin_password

# 外部 API Key (供其他服务调用)
API_KEY=

# 全局默认 Flow2API 服务器地址
# Docker Desktop: http://host.docker.internal:8000
# Linux: http://172.17.0.1:8000 或宿主机 IP
FLOW2API_URL=http://host.docker.internal:8000

# 全局默认连接 Token (从 Flow2API 后台 -> 插件配置 获取)
# 也可以在每个 Profile 中单独覆盖
CONNECTION_TOKEN=your_connection_token_here

# Token 刷新间隔 (分钟)
# 建议 60-360 分钟
REFRESH_INTERVAL=60

# 会话 TTL (分钟)，0 表示不自动过期
SESSION_TTL_MINUTES=1440

# CORS 允许的来源，逗号分隔，留空表示不启用 CORS
CORS_ORIGINS=
CORS_ALLOW_CREDENTIALS=false

# 配置持久化文件路径
CONFIG_FILE=/app/data/config.json

# VNC 密码
VNC_PASSWORD=flow2api

# 是否启用 VNC 登录入口（1=启用，0=关闭）
# 启用后：仅在点击「登录」时按需启动 VNC/Xvfb/noVNC，关闭浏览器后自动停止以省内存
ENABLE_VNC=1
